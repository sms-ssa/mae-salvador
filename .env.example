# ═══════════════════════════════════════════════════════════════
#  Programa Mãe Salvador — Variáveis de ambiente
#  Copie para .env e preencha os valores.
# ═══════════════════════════════════════════════════════════════

# ── Base Federal (CNS) ────────────────────────────────────────
# Pesquisa de cidadão por CPF (serviço SOAP PesquisarPacientePorCPF).
# Sem credenciais, a rota /api/cns/buscar retorna "não configurada".
CNS_FEDERAL_URL=http://177.20.6.29:8181/JAXWebserviceCnsMS/ServicoCns
CNS_FEDERAL_USER=
CNS_FEDERAL_PASSWORD=

# ── Banco da aplicação ───────────────────────────────────────
# PostgreSQL. Usado para gestante_cadastro e demais dados do programa.
# Migrations: database/migrations/
APP_DATABASE_URL=postgresql://usuario:senha@localhost:5432/mae_salvador
