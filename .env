# ═══════════════════════════════════════════════════════════════
#  Programa Mãe Salvador — Variáveis de ambiente
#  Copie para .env e preencha os valores.
# ═══════════════════════════════════════════════════════════════

# ── Base Federal (CNS) ────────────────────────────────────────
# Pesquisa de cidadão por CPF (serviço SOAP PesquisarPacientePorCPF).
# Sem credenciais, a rota /api/cns/buscar retorna "não configurada".
CNS_FEDERAL_URL=http://177.20.6.29:8181/JAXWebserviceCnsMS/ServicoCns
CNS_FEDERAL_USER=usr_cip_dml
CNS_FEDERAL_PASSWORD=lBLpOVaTO*Ri&_xo

# ── Banco da aplicação ───────────────────────────────────────
# PostgreSQL. Usado para gestante_cadastro e demais dados do programa.
# Migrations: database/migrations/
APP_DATABASE_URL="postgresql://postgres:123456@localhost:5432/mae_salvador?schema=public"
ESUS_DATABASE_URL="postgresql://postgres:NE9e6BApdLzR49VIkOiDTya~nX7~a@172.22.16.62:5433/esus?schema=public"


# ── e-SUS (PEC) — PostgreSQL ──────────────────────────────────
# Opcional. Se definido, a busca de cidadão (api/cns/buscar) consulta o e-SUS antes do SOAP.
# Formato: postgresql://usuario:senha@host:5432/nome_banco
# ESUS_DATABASE_URL=


# Banco alternativo CIP (SQL Server) — para buscar cidadãos para cadastro como gestante.
# Corresponde ao banco DB_CIP_DEV / tabela solicitacao_carteira_prioritaria.
# Mapeado de ConnectionStrings:DefaultConnection (Server; Database; User ID; Password).
# Deixe CIP_DATABASE_SERVER vazio para desativar a busca no CIP (cadastro apenas manual).
CIP_DATABASE_SERVER=172.22.16.19
CIP_DATABASE_NAME=DB_CIP_DEV
CIP_DATABASE_USER=usr_cip_dml
CIP_DATABASE_PASSWORD=Ph7=lBLpOVaTO*Ri&_xo
# Opcional: porta (padrão 1433)
# CIP_DATABASE_PORT=1433
# Opcional: true em desenvolvimento com certificado autoassinado
CIP_DATABASE_TRUST_CERTIFICATE=false


CNS_FEDERAL_URL=http://177.20.6.29:8181/JAXWebserviceCnsMS/ServicoCns
CNS_FEDERAL_USER=ServicoCnsMS
CNS_FEDERAL_PASSWORD=53rv!c0C7SM5